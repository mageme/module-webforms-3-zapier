<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="mm_webforms_form" resource="default" engine="innodb">
        <!-- Zapier Webhook Settings -->
        <column xsi:type="boolean" name="is_zapier_webhook_enabled" nullable="false" default="0" comment="Zapier Webhook Enabled"/>
        <column xsi:type="text" name="zapier_webhook_url" nullable="true" comment="Zapier Webhook URL"/>
    </table>

</schema>
